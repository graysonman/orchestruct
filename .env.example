# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=orchestruct
POSTGRES_PASSWORD=changeme
POSTGRES_DB=orchestruct_dev
# Note: hostname is "postgres" — the Docker Compose service name, not localhost
DATABASE_URL=postgresql://orchestruct:changeme@postgres:5432/orchestruct_dev

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── FastAPI / JWT ──────────────────────────────────────────────────────────────
# Generate a real key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_RANDOM_32_BYTE_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT=development

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
